# Copy to .env.local and fill in your values

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth Client ID (for redirect-based login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# OAuth redirect URI for Google authorization code flow.
# This must point to the backend callback endpoint and must match:
# 1) Google Console authorized redirect URI
# 2) backend GOOGLE_OAUTH_REDIRECT_URI
# For local dev: http://localhost:8000/api/v1/auth/google/callback
NEXT_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Optional: homepage demo image. Defaults to a bundled local public asset.
NEXT_PUBLIC_DEMO_IMAGE_URL=

# Optional: IndexNow verification key, 8-128 chars using a-z, A-Z, 0-9, or -
# Exposed at /indexnow-key.txt and used as keyLocation when submitting updated URLs.
INDEXNOW_KEY=

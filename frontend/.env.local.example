# Copy to .env.local and fill in your values

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth Client ID (for redirect-based login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# OAuth redirect URI – must match what's registered in Google Console
# and what GOOGLE_OAUTH_REDIRECT_URI is set to in the backend .env
# For local dev: NEXT_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback/google
NEXT_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback/google
